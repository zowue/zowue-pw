# github personal access token with repo and issues permissions
GITHUB_TOKEN=ghp_your_token_here

# comma-separated list of repositories to monitor
REPO=zowue/zowue-pw,zarazaex69/sedec

# webhook server port
GITHUB_WEBHOOK_PORT=8802

# working directory for cloned repositories (optional)
WORK_DIR=/tmp/zowue-analyzer

# qwen oauth tokens (get from ~/.qwen/oauth_creds.json after running qwen.js auth)
# these will be auto-updated when they expire
QWEN_ACCESS_TOKEN=your_access_token_here
QWEN_REFRESH_TOKEN=your_refresh_token_here
QWEN_EXPIRY_DATE=1234567890123
